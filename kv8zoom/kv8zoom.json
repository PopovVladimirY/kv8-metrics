                { "zoom_max": 3,  "rate_hz": 1  },
                { "zoom_max": 7,  "rate_hz": 5  },
                { "zoom_max": 12, "rate_hz": 15 },
                { "zoom_max": 17, "rate_hz": 30 },
                { "zoom_max": 22, "rate_hz": 100 }
            ]
        }
    }
