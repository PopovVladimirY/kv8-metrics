    "version": "0.2.0",
    "configurations": [
    {
        "name": "(Windows) kv8probe",
        "type": "cppvsdbg",
        "request": "launch",
        "program": "${workspaceFolder}/build/_output_/bin/kv8probe.exe",
        "args": [
            "--brokers", "localhost:19092", 
            "--security-proto", "sasl_plaintext", 
            "--sasl-mechanism", "PLAIN", 
            "--user", "kv8producer", 
            "--pass", "kv8secret",
            "--start-tick", "1000000",
            "--count", "10000000",
            "--channel", "kv8ts.test_scope_2"
        ]
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}/build/_output_/bin",
        "environment": [],
        "console": "externalTerminal"
    },
